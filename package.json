{
  "name": "portal-ies-rio-arba",
  "version": "1.0.0",
  "description": "Portal web para profesores del IES Río Arba",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint . --ext .js --ignore-pattern node_modules --ignore-pattern public/js/datos-prueba.js",
    "lint:fix": "eslint . --ext .js --fix --ignore-pattern node_modules",
    "format": "prettier --write \"**/*.{js,json,css,html}\"",
    "test": "jest --detectOpenHandles --forceExit"
  },
  "dependencies": {
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "googleapis": "^171.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "mysql2": "^3.11.0",
    "nodemailer": "^6.9.14",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.0",
    "supertest": "^6.3.4"
  }
}
